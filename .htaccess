# Waze Places PWA — Apache config
# Drop-in: clonar para /var/www/html/wazeplaces e ter AllowOverride All
# em /var/www/html já basta. Se AllowOverride for None (default no RHEL)
# este arquivo é ignorado — a app ainda funciona, só perde cache/headers
# extras.

# mod_pagespeed reordena/combina/minifica scripts e quebra a ordem de
# carregamento (api.js precisa vir antes de app.js). Desabilita pra esta app.
<IfModule pagespeed_module>
    ModPagespeed off
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{REQUEST_URI} /api/ [OR]
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https://venue-image.waze.com https://social-row.waze.com; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://venue-image.waze.com https://social-row.waze.com; worker-src 'self' blob:;"

    # JS/CSS/manifest: sempre revalidar com o servidor (ETag/Last-Modified).
    # Sem isso o browser cacheava 1 mês via ExpiresByType e F5 não pegava versão
    # nova — só Ctrl+Shift+R funcionava (que mobile não tem). Browser ainda usa
    # cache se servidor responder 304, então não há perda de performance real.
    # ATENÇÃO: regra genérica vem ANTES da específica do service-worker.js
    # porque Header set do bloco posterior sobrescreve o anterior.
    <FilesMatch "\.(js|css|json)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>

    <FilesMatch "service-worker\.js$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>

    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache"
    </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/html "access plus 0 seconds"
    # JS/CSS/manifest gerenciados via Cache-Control: no-cache na seção mod_headers.
    # Não setar ExpiresByType aqui pra evitar header Expires sobrescrevendo.
</IfModule>

Options -Indexes

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "(\.git|README\.md|start\.sh|start\.bat|\.gitignore)$">
    Require all denied
</FilesMatch>
